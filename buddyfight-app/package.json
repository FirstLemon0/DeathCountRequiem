{
  "name": "buddyfight-netplay-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "Buddyfight browser prototype with room-based netplay.",
  "main": "server/authoritative-server.js",
  "scripts": {
    "test": "node tests/effects-regression.test.js",
    "start": "node server/authoritative-server.js --host 0.0.0.0",
    "start:auth": "node server/authoritative-server.js --host 0.0.0.0",
    "start:auth:local": "node server/authoritative-server.js --host 127.0.0.1 --port 4174 --open",
    "start:public": "node server/authoritative-server.js --host 0.0.0.0",
    "start:relay": "node netplay-server.js --host 0.0.0.0",
    "start:local": "node netplay-server.js --host 127.0.0.1 --port 4173",
    "start:lan": "node netplay-server.js --host 0.0.0.0 --port 4173"
  },
  "engines": {
    "node": ">=18"
  }
}
